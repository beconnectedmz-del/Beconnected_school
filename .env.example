# ─── POSTGRES ─────────────────────────────────────────────────────────────────
POSTGRES_DB=eduhub
POSTGRES_USER=eduhub_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ─── MINIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=eduhub_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_MATERIALS=materials
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_PRESENTATIONS=presentations

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h
BCRYPT_COST=12

# ─── PAYMENT GATEWAY ──────────────────────────────────────────────────────────
# Set PAYMENT_GATEWAY=mpesa for M-Pesa (Mozambique) or stripe for international
PAYMENT_GATEWAY=mpesa
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# M-Pesa / Vodacom IPG (Mozambique)
MPESA_BASE_URL=https://api.sandbox.vm.co.mz:8443
MPESA_API_KEY=your_mpesa_api_key
MPESA_PUBLIC_KEY=your_mpesa_public_key
MPESA_SP_CODE=your_service_provider_code

# Stripe (international fallback)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
PAYMENT_GATEWAY_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret

# ─── COMMISSION RATES (%) ─────────────────────────────────────────────────────
TEACHER_COMMISSION_RATE=70
PLATFORM_COMMISSION_RATE=20
AFFILIATE_COMMISSION_RATE=10

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@eduhub.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="EduHub <noreply@eduhub.com>"

# ─── WEB PUSH (VAPID) ─────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ─── STREAMING ────────────────────────────────────────────────────────────────
MAX_ROOM_PARTICIPANTS=50
RECORDING_ENABLED=true
NODE_CLUSTER_WORKERS=4

# ─── AI SERVICE ───────────────────────────────────────────────────────────────
MATCH_ALGORITHM=weighted_score
RECOMMENDATION_LIMIT=10

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# ─── UPLOAD ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=2048

# ─── APP ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
APP_ENV=development
LOG_LEVEL=info

# ─── COURSE SERVICE ───────────────────────────────────────────────────────────
COURSE_SERVICE_URL=http://course-service:8088

# ─── FUNNEL SERVICE ───────────────────────────────────────────────────────────
FUNNEL_SERVICE_URL=http://funnel-service:8089
