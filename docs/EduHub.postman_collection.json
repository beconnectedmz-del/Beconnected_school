{
  "info": {
    "name": "EduHub API",
    "description": "Colecção completa da API EduHub — plataforma de ensino online",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"estudante@eduhub.com\",\n  \"password\": \"password123\",\n  \"role\": \"student\",\n  \"full_name\": \"João Silva\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json(); if(r.access_token){ pm.collectionVariables.set('token', r.access_token); pm.collectionVariables.set('refresh_token', r.refresh_token); }"] } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"estudante@eduhub.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"estudante@eduhub.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "👨‍🎓 Estudantes",
      "item": [
        {
          "name": "Criar Perfil",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/students/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"João Silva\",\n  \"date_of_birth\": \"2000-05-15\",\n  \"proficiency_level\": \"beginner\",\n  \"learning_goals\": \"Aprender inglês para negócios\",\n  \"timezone\": \"Africa/Maputo\"\n}" }
          }
        },
        {
          "name": "Actualizar Perfil",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/students/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"learning_goals\": \"Aprender inglês e francês\"\n}" }
          }
        },
        {
          "name": "Submeter Diagnóstico",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/students/diagnostic",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"q1\": true,\n  \"q2\": false,\n  \"q3\": true,\n  \"q4\": true,\n  \"preferred_discipline\": \"ingles\"\n}" }
          }
        },
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/students/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Recomendações (AI)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/students/recommendations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "👨‍🏫 Professores",
      "item": [
        {
          "name": "Criar Perfil",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/teachers/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Maria Santos\",\n  \"bio\": \"Professora de inglês com 10 anos de experiência\",\n  \"timezone\": \"Africa/Maputo\"\n}" }
          }
        },
        {
          "name": "Definir Disponibilidade",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/teachers/availability",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "[\n  { \"day_of_week\": 1, \"start_time\": \"08:00\", \"end_time\": \"12:00\", \"timezone\": \"Africa/Maputo\" },\n  { \"day_of_week\": 3, \"start_time\": \"14:00\", \"end_time\": \"18:00\", \"timezone\": \"Africa/Maputo\" },\n  { \"day_of_week\": 5, \"start_time\": \"09:00\", \"end_time\": \"13:00\", \"timezone\": \"Africa/Maputo\" }\n]" }
          }
        },
        {
          "name": "Listar Professores (público)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/teachers/list?discipline=ingles&min_rating=4&page=1&page_size=10",
              "query": [
                { "key": "discipline", "value": "ingles" },
                { "key": "min_rating", "value": "4" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Perfil Público do Professor",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/teachers/:id",
            "variable": [{ "key": "id", "value": "TEACHER_PROFILE_UUID" }]
          }
        },
        {
          "name": "Dashboard do Professor",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/teachers/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "📚 Cursos",
      "item": [
        {
          "name": "Listar Cursos (público)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/courses?discipline=ingles&level=beginner&sort=popular&page=1",
              "query": [
                { "key": "discipline", "value": "ingles" },
                { "key": "level", "value": "beginner" },
                { "key": "sort", "value": "popular" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Detalhe do Curso",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/:id",
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        },
        {
          "name": "Criar Curso (professor)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/courses",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"discipline_id\": \"DISCIPLINE_UUID\",\n  \"title\": \"Inglês para Iniciantes\",\n  \"description\": \"Curso completo de inglês do zero\",\n  \"level\": \"beginner\",\n  \"price\": 2500.00,\n  \"lesson_type\": \"recorded\",\n  \"total_hours\": 20\n}" }
          }
        },
        {
          "name": "Publicar Curso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/courses/:id/publish",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"published\": true }" },
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        },
        {
          "name": "Adicionar Aula ao Curso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/courses/:id/lessons",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Aula 1 - Saudações\",\n  \"description\": \"Aprenda a cumprimentar em inglês\",\n  \"lesson_order\": 1,\n  \"duration_minutes\": 30,\n  \"is_free_preview\": true\n}" },
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        },
        {
          "name": "Listar Aulas do Curso",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/courses/:id/lessons",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        }
      ]
    },
    {
      "name": "📋 Matrículas",
      "item": [
        {
          "name": "Matricular em Curso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/courses/:id/enroll",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        },
        {
          "name": "Meus Cursos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/enrollments/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Actualizar Progresso da Aula",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/courses/:id/lessons/:lesson_id/progress",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"watched_seconds\": 1234,\n  \"completed\": true\n}" },
            "variable": [{ "key": "id", "value": "COURSE_UUID" }, { "key": "lesson_id", "value": "LESSON_UUID" }]
          }
        }
      ]
    },
    {
      "name": "🎥 Sessões Ao Vivo",
      "item": [
        {
          "name": "Agendar Sessão",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"teacher_id\": \"TEACHER_PROFILE_UUID\",\n  \"course_id\": \"COURSE_UUID\",\n  \"scheduled_at\": \"2025-02-01T10:00:00Z\",\n  \"duration_minutes\": 60\n}" }
          }
        },
        {
          "name": "Minhas Sessões",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/sessions/my?status=scheduled",
              "query": [{ "key": "status", "value": "scheduled" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Cancelar Sessão",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sessions/:id/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"reason\": \"Indisponibilidade inesperada\" }" },
            "variable": [{ "key": "id", "value": "SESSION_UUID" }]
          }
        }
      ]
    },
    {
      "name": "⭐ Feedback",
      "item": [
        {
          "name": "Submeter Avaliação",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/feedback",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"teacher_id\": \"TEACHER_PROFILE_UUID\",\n  \"course_id\": \"COURSE_UUID\",\n  \"rating\": 5,\n  \"comment\": \"Excelente professora! Muito didática e paciente.\"\n}" }
          }
        },
        {
          "name": "Feedbacks do Professor (público)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/feedback/teacher/:teacher_id?page=1&page_size=10",
              "query": [{ "key": "page", "value": "1" }, { "key": "page_size", "value": "10" }]
            },
            "variable": [{ "key": "teacher_id", "value": "TEACHER_PROFILE_UUID" }]
          }
        },
        {
          "name": "Responder a Feedback (professor)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/feedback/:id/respond",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"response\": \"Obrigada! Foi um prazer ensinar.\" }" },
            "variable": [{ "key": "id", "value": "FEEDBACK_UUID" }]
          }
        }
      ]
    },
    {
      "name": "💰 Pagamentos",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/payments/checkout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"course_id\": \"COURSE_UUID\",\n  \"gross_amount\": 2500.00,\n  \"payment_method\": \"mpesa\",\n  \"affiliate_code\": \"ABCD1234\"\n}" }
          }
        },
        {
          "name": "Histórico de Pagamentos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/payments/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Ganhos do Professor",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/payments/earnings?from=2025-01-01&to=2025-01-31",
              "query": [{ "key": "from", "value": "2025-01-01" }, { "key": "to", "value": "2025-01-31" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Solicitar Payout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/payouts/request",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 15000.00,\n  \"payout_method\": \"mpesa\"\n}" }
          }
        }
      ]
    },
    {
      "name": "📣 Funil de Vendas",
      "item": [
        {
          "name": "Capturar Lead (público)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/leads",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"prospecto@gmail.com\",\n  \"name\": \"Carlos Machava\",\n  \"phone\": \"+258841234567\",\n  \"interest_discipline\": \"ingles\",\n  \"interest_level\": \"beginner\",\n  \"affiliate_code\": \"ABCD1234\",\n  \"utm_source\": \"facebook\",\n  \"utm_campaign\": \"jan2025\"\n}" }
          }
        },
        {
          "name": "Tracking de Clique de Afiliado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/affiliates/click?code=ABCD1234",
              "query": [{ "key": "code", "value": "ABCD1234" }]
            }
          }
        },
        {
          "name": "Tornar-se Afiliado",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/affiliates/register",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"payout_method\": \"mpesa\",\n  \"payout_details\": \"+258841234567\"\n}" }
          }
        },
        {
          "name": "Dashboard do Afiliado",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/affiliates/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Relatório do Afiliado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/affiliates/report?from=2025-01-01&to=2025-01-31",
              "query": [{ "key": "from", "value": "2025-01-01" }, { "key": "to", "value": "2025-01-31" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "📁 Conteúdo (Upload)",
      "item": [
        {
          "name": "Upload de Vídeo",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/content/upload/video",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "video", "type": "file", "src": "/path/to/video.mp4" },
                { "key": "course_id", "value": "COURSE_UUID", "type": "text" },
                { "key": "lesson_id", "value": "LESSON_UUID", "type": "text" },
                { "key": "title", "value": "Aula 1 - Saudações", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "URL Assinada para Streaming",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/content/signed-url?bucket=videos&object=path/to/video.mp4",
              "query": [{ "key": "bucket", "value": "videos" }, { "key": "object", "value": "path/to/video.mp4" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "🤖 AI / Match",
      "item": [
        {
          "name": "Match Professor-Estudante",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/match",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"student_id\": \"USER_UUID\",\n  \"discipline_slug\": \"ingles\",\n  \"level\": \"beginner\",\n  \"preferred_days\": [1, 3, 5],\n  \"max_price_per_hour\": 500,\n  \"limit\": 5\n}" }
          }
        },
        {
          "name": "Recomendações Personalizadas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/recommendations/:student_id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "variable": [{ "key": "student_id", "value": "USER_UUID" }]
          }
        }
      ]
    },
    {
      "name": "🔔 Notificações",
      "item": [
        {
          "name": "Listar Notificações",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Marcar Como Lida",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notifications/:id/read",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "variable": [{ "key": "id", "value": "NOTIFICATION_UUID" }]
          }
        },
        {
          "name": "Contagem de Não Lidas",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications/unread-count",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Subscrever Web Push",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/push/subscribe",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"subscription\": {\n    \"endpoint\": \"https://fcm.googleapis.com/...\",\n    \"keys\": { \"auth\": \"...\", \"p256dh\": \"...\" }\n  }\n}" }
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "Validar Professor",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/teachers/:id/validate",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"validated\": true }" },
            "variable": [{ "key": "id", "value": "TEACHER_PROFILE_UUID" }]
          }
        },
        {
          "name": "Validar Curso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/courses/:id/validate",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"validated\": true }" },
            "variable": [{ "key": "id", "value": "COURSE_UUID" }]
          }
        },
        {
          "name": "Aulas Pendentes de Revisão",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/content/pending",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Aprovar Aula",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/content/lessons/:id/approve",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "variable": [{ "key": "id", "value": "LESSON_UUID" }]
          }
        },
        {
          "name": "Relatório Financeiro",
          "request": {
            "method": "GET",
